# el34 ips — local Suricata rules (sid >= 1000000).
# secuops-easy 정규화 2026-05-27: 기존 룰의 잘못된 옵션 문법(!src_ip, 본문 ipvar)으로
# 전 룰 로딩 실패(rules_loaded 0) → 올바른 문법으로 재작성. el34 는 폐쇄망이라 공격자도
# HOME_NET 안에 있으므로 헤더는 any any -> any any 로 둔다(실전은 $EXTERNAL_NET→$HOME_NET).
# GUI(suricata_edu_gui)가 만드는 학생 룰은 sid >= 9000000 으로 이 아래에 누적된다.

alert http any any -> any any (msg:"EL34 SQL Injection - UNION SELECT"; flow:established,to_server; http.uri; content:"UNION"; nocase; content:"SELECT"; nocase; distance:0; classtype:web-application-attack; sid:1000001; rev:2;)
alert http any any -> any any (msg:"EL34 XSS - script tag"; flow:established,to_server; http.uri; content:"<script"; nocase; classtype:web-application-attack; sid:1000002; rev:2;)
alert http any any -> any any (msg:"EL34 Bot UA - sqlmap"; flow:established,to_server; http.user_agent; content:"sqlmap"; nocase; classtype:web-application-attack; sid:1000003; rev:2;)
alert http any any -> any any (msg:"EL34 Path Traversal Attempt"; flow:established,to_server; http.uri; content:"../"; classtype:web-application-attack; sid:1000004; rev:2;)
alert tcp any any -> any any (msg:"EL34 Possible nmap SYN scan"; flags:S; threshold:type both, track by_src, count 30, seconds 10; classtype:attempted-recon; sid:1000005; rev:2;)
