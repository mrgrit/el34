# =========================================================
# el34 실습 환경 설정 (단일 VM Docker)
# =========================================================
# 처음 한 번:
#   cp .env.example .env
# 외부 LLM 서버를 쓸 거면 LLM_BASE_URL 만 수정.

# ----- 외부 LLM (선택, Bastion AI 기능용) -----
LLM_BASE_URL=
LLM_MODEL=gemma3:4b

# ----- AICompanion LLM 백엔드 (선택) -----
# 기본 mock(키워드 시뮬). 실제 모델은 보통 web /admin 에서 런타임 지정(볼륨에 영속)하므로
# 아래는 배포 초기 기본값일 뿐. 부팅부터 실제 모델로 시작하려면 ollama 로 설정.
AICOMPANION_LLM_BACKEND=mock

# ----- SSH 계정 (모든 컨테이너 공통) -----
SSH_USER=ccc
SSH_PASS=ccc

# ----- 외부 노출 포트 -----
PORT_HTTP=80              # http://VMIP/ 랜딩 + JuiceShop reverse proxy
PORT_HTTPS=443            # https://VMIP/
PORT_BASTION_SSH=2204     # ssh ccc@VMIP -p 2204 (점프 호스트)
PORT_ATTACKER_SSH=2202    # ssh ccc@VMIP -p 2202 (직접 attacker 진입)
PORT_PORTAL=8000          # http://VMIP:8000/ 관리 포털
PORT_SIEM_DASH=5601       # http://VMIP:5601/ SIEM lite UI
PORT_BASTION_API=9100     # http://VMIP:9100/health Bastion API

# ----- API 인증 -----
API_KEY=ccc-api-key-2026
