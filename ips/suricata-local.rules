# el34 ips — local Suricata rules (sid >= 1000000).

alert http any any -> any any (msg:"EL34 SQL Injection - UNION SELECT"; \
    flow:established,to_server; content:"UNION"; nocase; content:"SELECT"; nocase; \
    distance:0; within:30; sid:1000001; rev:1;)

alert http any any -> any any (msg:"EL34 XSS - script tag"; \
    flow:established,to_server; content:"<script"; nocase; \
    sid:1000002; rev:1;)

alert http any any -> any any (msg:"EL34 Bot UA - sqlmap"; \
    flow:established,to_server; content:"User-Agent|3a 20|sqlmap"; nocase; http_header; \
    sid:1000003; rev:1;)

alert http any any -> any any (msg:"EL34 Path Traversal Attempt"; \
    flow:established,to_server; content:"../"; pcre:"/\.\.\//"; \
    sid:1000004; rev:1;)

alert tcp any any -> any any (msg:"EL34 Possible nmap SYN scan"; \
    flags:S; threshold:type both, track by_src, count 30, seconds 10; \
    sid:1000005; rev:1;)
